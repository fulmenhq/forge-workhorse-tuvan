# Tuvan Environment Variables Template
# Copy this file to .env and customize for your local development
#
# CDRL INSTRUCTIONS:
# When customizing this template, update the TUVAN_ prefix to match
# your application name from .fulmen/app.yaml (e.g., MYAPI_PORT)

# Server Configuration
#
# Canonical (nested mapping):
TUVAN_SERVER_HOST=localhost
TUVAN_SERVER_PORT=8080
#
# Template-friendly aliases (supported; do not set both alias + canonical):
# TUVAN_HOST=localhost
# TUVAN_PORT=8080

# Control Plane (admin)
#
# Recommended defaults:
# - Bind to loopback to minimize exposure
# - Set ADMIN_TOKEN if you intend to bind control plane to non-loopback
TUVAN_CONTROL_PLANE_HOST=127.0.0.1
TUVAN_CONTROL_PLANE_PORT=8081
TUVAN_ADMIN_BASE_PATH=/control

# Logging Configuration
#
# Canonical (nested mapping):
TUVAN_LOGGING_LEVEL=info
TUVAN_LOGGING_PROFILE=structured
#
# Template-friendly aliases (supported; do not set both alias + canonical):
# TUVAN_LOG_LEVEL=info
# TUVAN_LOG_PROFILE=structured

# Observability
TUVAN_METRICS_ENABLED=true

# Note: metrics.port exists in config for future isolation patterns, but /metrics
# is currently served on the data plane.
TUVAN_METRICS_PORT=0

# Config locations
#
# Use XDG / Fulmen config directory overrides instead of per-app config-path env vars:
# - XDG_CONFIG_HOME=/custom/config/home
# - FULMEN_CONFIG_HOME=/custom/fulmen/config/home

# Admin Endpoint (optional - for remote signal injection)
# TUVAN_ADMIN_TOKEN=your-secret-token-here

# Data Plane Auth (starter)
#
# Quick-start env var aliases (supported by this template):
#   TUVAN_AUTH_ENABLED=true
#   TUVAN_AUTH_MODE=basicAuth
#   TUVAN_AUTH_BASIC_USER=admin
#   TUVAN_AUTH_BASIC_PASSWORD=change-me
#
# Also supported (nested mapping via tsfulmen/config):
#   TUVAN_DATA_PLANE_AUTH_ENABLED=true
#   TUVAN_DATA_PLANE_AUTH_AUTH_MODE=basicAuth
#   TUVAN_DATA_PLANE_AUTH_AUTH_BASIC_USER=admin
#   TUVAN_DATA_PLANE_AUTH_AUTH_BASIC_PASSWORD=change-me
#
# Note: keep auth disabled until you need it.
# TUVAN_DATA_PLANE_AUTH_ENABLED=false
# TUVAN_DATA_PLANE_AUTH_AUTH_MODE=disabled
# TUVAN_DATA_PLANE_AUTH_AUTH_BASIC_USER=
# TUVAN_DATA_PLANE_AUTH_AUTH_BASIC_PASSWORD=

# Application Settings
# Add your application-specific environment variables below
# Remember to use the TUVAN_ prefix (or your custom prefix after CDRL)
