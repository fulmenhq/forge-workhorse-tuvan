# Tuvan Environment Variables Template
# Copy this file to .env and customize for your local development
#
# CDRL INSTRUCTIONS:
# When customizing this template, update the TUVAN_ prefix to match
# your application name from .fulmen/app.yaml (e.g., MYAPI_PORT)

# Server Configuration
TUVAN_HOST=localhost
TUVAN_PORT=8080
TUVAN_METRICS_PORT=9090

# Logging Configuration
# Levels: trace, debug, info, warn, error
TUVAN_LOG_LEVEL=info
# Profiles: simple, structured, enterprise
TUVAN_LOG_PROFILE=structured

# Observability
TUVAN_METRICS_ENABLED=true
TUVAN_HEALTH_PORT=8080

# Configuration Paths (optional - defaults to XDG paths)
# TUVAN_CONFIG_PATH=./config/tuvan.yaml

# Admin Endpoint (optional - for remote signal injection)
# TUVAN_ADMIN_TOKEN=your-secret-token-here

# Application Settings
# Add your application-specific environment variables below
# Remember to use the TUVAN_ prefix (or your custom prefix after CDRL)
