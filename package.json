{
  "name": "@fulmenhq/forge-workhorse-tuvan",
  "version": "0.1.0",
  "description": "Fulmen TypeScript workhorse template - production-ready foundation for robust, scalable Node.js backends",
  "author": "3 Leaps, LLC",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "bin": {
    "tuvan": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "config",
    "schemas",
    ".fulmen",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts serve",
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "check:all": "make check-all",
    "clean": "make clean"
  },
  "dependencies": {
    "@fulmenhq/tsfulmen": "^0.1.8",
    "commander": "^12.1.0",
    "fastify": "^5.1.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^4.0.7",
    "@vitest/ui": "^2.1.5",
    "bun-types": "^1.3.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  },
  "keywords": [
    "fulmen",
    "workhorse",
    "template",
    "typescript",
    "fastify",
    "cli",
    "server",
    "production",
    "enterprise"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fulmenhq/forge-workhorse-tuvan.git"
  },
  "bugs": {
    "url": "https://github.com/fulmenhq/forge-workhorse-tuvan/issues"
  },
  "homepage": "https://github.com/fulmenhq/forge-workhorse-tuvan#readme"
}
