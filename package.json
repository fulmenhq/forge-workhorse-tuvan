{
  "name": "@fulmenhq/forge-workhorse-tuvan",
  "version": "0.1.6",
  "description": "Fulmen TypeScript workhorse template - production-ready foundation for robust, scalable Node.js backends",
  "author": "3 Leaps, LLC",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.0.0"
  },
  "bin": {
    "tuvan": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "config",
    "schemas",
    ".fulmen",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts serve",
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "check:all": "make check-all",
    "build:all": "bun scripts/build-all.ts",
    "build:local": "bun build src/index.ts --compile --outfile dist/tuvan",
    "clean": "make clean"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.5",
    "@fulmenhq/tsfulmen": "0.3.0",
    "@sinclair/typebox": "^0.34.48",
    "commander": "^15.0.0",
    "fastify": "^5.7.4",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.19.9",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "bun-types": "^1.3.14",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "fulmen",
    "workhorse",
    "template",
    "typescript",
    "fastify",
    "cli",
    "server",
    "production",
    "enterprise"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fulmenhq/forge-workhorse-tuvan.git"
  },
  "bugs": {
    "url": "https://github.com/fulmenhq/forge-workhorse-tuvan/issues"
  },
  "homepage": "https://github.com/fulmenhq/forge-workhorse-tuvan#readme"
}
